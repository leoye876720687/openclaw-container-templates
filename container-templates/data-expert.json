{
  "template": {
    "id": "data-expert",
    "name": "Data Expert / 数据专家",
    "description": "数据分析专用容器",
    "version": "1.0.0"
  },

  "container": {
    "namePrefix": "openclaw-agent",
    "image": "docker-openclaw-openclaw:latest",
    "internalPort": 18789,
    "healthCheck": {
      "cmd": "curl -f http://127.0.0.1:18789/ || exit 1",
      "interval": "30s",
      "timeout": "10s",
      "retries": 3
    },
    "restart": "unless-stopped"
  },

  "skills": [
    "data-model-designer",
    "data-reconciliation-exceptions",
    "excel-xlsx",
    "statistics",
    "feishu-bitable",
    "prompt-optimizer"
  ],

  "workspace": {
    "directories": ["input", "output", "scripts", "memory", "temp"]
  },

  "config": {
    "bind": "loopback",
    "authMode": "token",
    "nativeSkills": "auto"
  }
}
